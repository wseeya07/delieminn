---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function extractYouTubeId(url) {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|v=|\/embed\/)([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}

// MD içindeki ilk görseli bulmak için basit bir regex (Cover Image niyetine)
function extractFirstImage(body) {
  if(!body) return null;
  const match = body.match(/!\[.*?\]\((.*?)\)/);
  return match ? match[1] : null;
}
---
<BaseLayout title="Projeler — Deli Eminn Motoexper" description="ECU yazılım, dyno test ve performans modifikasyon projelerimiz.">
  <Navbar />
  <main class="section projects-page">
    <div class="container">
      <SectionHeader label="Tüm Çalışmalar">Projelerimiz</SectionHeader>

      {sorted.length > 0 ? (
        <div class="projects-grid">
          {sorted.map((project) => {
            const ytId = extractYouTubeId(project.data.videoUrl);
            const firstImg = extractFirstImage(project.body); // proj.body Astro 4'te raw md
            
            // Thumbnail önceliği: 1. Yt MQ Default, 2. Yazıdaki ilk resim, 3. Kapalı Kutu (Placeholder)
            const thumbUrl = ytId 
              ? `https://img.youtube.com/vi/${ytId}/hqdefault.jpg` 
              : defaultCoverImageFallback(); // Fonksiyon çağrısı yerine direkt resim urlsi de olur

            const coverUrl = ytId ? `https://img.youtube.com/vi/${ytId}/maxresdefault.jpg` : (firstImg || '/images/bgg.jpg');

            const formattedDate = new Date(project.data.date).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' });
            
            return (
              <a href={`/projeler/${project.id.split('.')[0]}`} class="project-card">
                <div class="project-card__media">
                  <img src={coverUrl} alt={project.data.title} loading="lazy" />
                  {ytId && (
                    <div class="project-card__play">
                      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  )}
                </div>

                <div class="project-card__info">
                  <div class="project-card__meta">
                    <span class="project-card__category">{project.data.category}</span>
                    <span class="project-card__date">{formattedDate}</span>
                  </div>
                  <h3 class="project-card__title">{project.data.title}</h3>
                  {project.data.brand && <span class="project-card__brand">{project.data.brand}</span>}
                  
                  <div class="project-card__action">
                    <span>Detayları İncele</span>
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="projects-empty">Projeler yakında eklenecek.</p>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .projects-page { padding-top: 8rem; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  
  .project-card:hover {
    transform: translateY(-5px);
    border-color: rgba(230,57,70,0.4);
    box-shadow: 0 15px 30px rgba(0,0,0,0.5);
  }

  .project-card__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #111;
  }

  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-card__media img {
    transform: scale(1.05);
  }

  .project-card__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background: rgba(230,57,70,0.9);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    box-shadow: 0 4px 15px rgba(230,57,70,0.4);
  }
  .project-card__play svg {
    width: 24px;
    height: 24px;
    margin-left: 3px;
  }

  .project-card__info {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .project-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .project-card__category {
    font-size: var(--text-caption);
    color: var(--color-accent);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .project-card__date {
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
  }

  .project-card__title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.3;
    margin-bottom: var(--space-xs);
  }

  .project-card__brand {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .project-card__action {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    transition: color 0.3s ease;
  }
  
  .project-card:hover .project-card__action {
    color: var(--color-accent);
  }

  .projects-empty {
    text-align: center;
    color: var(--color-text-tertiary);
    padding: 4rem 0;
  }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
