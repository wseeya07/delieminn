---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import site from '../../data/site.json';

export async function getStaticPaths() {
  return site.services.map((svc) => {
    return {
      params: { id: svc.id },
      props: { svc },
    };
  });
}

const { svc } = Astro.props;
---
<BaseLayout title={`${svc.title} - Deli Eminn MotoExperTR`}>
  <Navbar />
  
  <main class="service-page">
    <header class="service-hero reveal">
      <div class="service-hero__glow"></div>
      <div class="container service-hero__content">
        <div class="service-hero__title-wrapper">
          <span class="service-hero__icon">{svc.icon}</span>
          <h1 class="service-hero__title">{svc.title}</h1>
        </div>
      </div>
    </header>

    <article class="service-content container">
      <div class="service-split">
        {/* SOL: METINLER VE LİSTE */}
        <div class="service-split__left">
          {svc.subtitle && (
            <blockquote class="service-quote reveal-stagger">
              “{svc.subtitle}”
            </blockquote>
          )}

          <div class="service-description reveal-stagger">
            <p>{svc.description}</p>
          </div>

          {svc.list && svc.list.length > 0 && (
            <div class="service-features reveal-stagger">
              <h3 class="service-features__title">{svc.listTitle}</h3>
              <ul class="service-features__list">
                {svc.list.map((item) => (
                  <li>
                    <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        {/* SAĞ: GÖRSEL VE AKSİYONLAR */}
        <div class="service-split__right reveal">
          {svc.image && (
            <div class="service-image-wrapper">
              <div class="service-image__frame"></div>
              <img src={svc.image} alt={svc.title} class="service-image" />
            </div>
          )}

          <div class="service-action-box">
            {svc.closing && (
              <div class="service-closing">
                <p class="service-closing__author">DeliEminn der ki:</p>
                <p class="service-closing__text">"{svc.closing}"</p>
              </div>
            )}
            
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="cta-primary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              Bilgi / Randevu Al
            </a>
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .service-page {
    padding-top: 80px;
    background: var(--color-bg-primary);
    min-height: 100vh;
  }

  /* KÜÇÜLTÜLMÜŞ YATAY HERO */
  .service-hero {
    position: relative;
    padding: 60px 0 40px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    overflow: hidden;
  }

  .service-hero__glow {
    position: absolute;
    top: -50%;
    left: 20%;
    width: 60%;
    height: 100%;
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 60%);
    opacity: 0.1;
    filter: blur(80px);
    z-index: 0;
  }

  .service-hero__content {
    position: relative;
    z-index: 1;
  }

  .service-hero__title-wrapper {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .service-hero__icon {
    font-size: 2.5rem;
    background: rgba(255,255,255,0.03);
    padding: 0.8rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-hero__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-white);
    margin: 0;
  }

  /* SPLIT LAYOUT */
  .service-content {
    padding: var(--space-2xl) var(--space-md);
  }

  .service-split {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  /* SOL: METİNLER */
  .service-split__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .service-quote {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-style: italic;
    color: var(--color-accent);
    line-height: 1.4;
    padding-left: 1rem;
    border-left: 4px solid var(--color-accent);
    margin: 0;
  }

  .service-description {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    text-align: justify;
  }
  
  .service-description p { margin: 0; }

  .service-features {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .service-features__title {
    font-size: 1.2rem;
    color: var(--color-white);
    margin-bottom: var(--space-md);
    font-weight: 600;
  }

  .service-features__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .service-features__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  .check-icon {
    width: 20px;
    height: 20px;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* SAĞ: RESİM VE KAPANIŞ */
  .service-split__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    position: sticky;
    top: 100px;
  }

  .service-image-wrapper {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .service-image__frame {
    position: absolute;
    inset: 0;
    border: 2px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    pointer-events: none;
    z-index: 2;
  }

  .service-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 20px rgba(230,57,70,0.2);
    pointer-events: none;
    z-index: 3;
    border-radius: var(--radius-lg);
  }

  .service-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    aspect-ratio: 4/3;
    transition: transform 0.5s ease;
  }
  .service-image-wrapper:hover .service-image {
    transform: scale(1.05);
  }

  .service-action-box {
    background: var(--color-bg-card);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .service-closing {
    margin-bottom: var(--space-xl);
  }

  .service-closing__author {
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .service-closing__text {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-white);
    line-height: 1.5;
    font-style: italic;
  }

  .cta-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    background: var(--color-accent);
    color: var(--color-white);
    padding: 1rem 2rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    width: 100%;
  }

  .cta-primary:hover {
    background: var(--color-accent-hover);
    box-shadow: 0 0 20px rgba(230,57,70,0.4);
    transform: translateY(-2px);
  }


  @media (max-width: 900px) {
    .service-split {
      grid-template-columns: 1fr;
    }
    
    .service-split__right {
      position: static;
      order: -1; /* Resmi mobilde üste alıyoruz */
    }

    .service-features__list {
      grid-template-columns: 1fr;
    }

    .service-hero__title-wrapper {
      justify-content: center;
    }
  }
</style>
