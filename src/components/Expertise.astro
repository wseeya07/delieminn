---
import site from '../data/site.json';
import SectionHeader from './ui/SectionHeader.astro';
---
<section class="section" id="uzmanlik">
  <div class="container">
    <SectionHeader label="Ne Yapıyoruz">Uzmanlık Alanlarımız</SectionHeader>
    <div class="expertise__grid reveal-stagger">
      {site.expertise.map((item) => (
        <div class="expertise__card">
          <span class="expertise__icon">{item.icon}</span>
          <h3 class="expertise__title">{item.title}</h3>
          <p class="expertise__desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .expertise__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .expertise__card {
    background: var(--color-bg-card);
    border: var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-lg);
    transition: all var(--transition-base);
  }
  .expertise__card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--glow-red);
  }

  .expertise__icon {
    font-size: 1.8rem;
    display: block;
    margin-bottom: var(--space-md);
  }

  .expertise__title {
    font-size: var(--text-h3);
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .expertise__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-small);
    line-height: 1.65;
  }

  @media (max-width: 1024px) { .expertise__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .expertise__grid { grid-template-columns: 1fr; } }
</style>
