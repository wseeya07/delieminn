---
import SectionHeader from './ui/SectionHeader.astro';
---
<section class="section" id="youtube">
  <div class="container">
    <SectionHeader label="YouTube">Son Videolarımız</SectionHeader>
    <div class="yt-grid" id="ytGrid">
      <div class="yt-loading">Videolar yükleniyor...</div>
    </div>
    <div class="yt-more">
      <a href="https://youtube.com/@delieminn" target="_blank" rel="noopener noreferrer" class="yt-more__link">
        Tüm Videolar →
      </a>
    </div>
  </div>
</section>

<script>
  async function loadYouTubeVideos() {
    const grid = document.getElementById('ytGrid');
    try {
      const res = await fetch('/api/youtube');
      if (!res.ok) throw new Error();
      const videos = await res.json();

      if (!videos.length) {
        grid.innerHTML = '<p style="color:#888;text-align:center">Videolar yüklenemedi.</p>';
        return;
      }

      grid.innerHTML = videos.map(v => `
        <a href="https://www.youtube.com/watch?v=${v.id}" target="_blank" rel="noopener noreferrer" class="yt-card">
          <div class="yt-card__thumb">
            <img src="${v.thumbnail}" alt="${v.title}" loading="lazy" />
            <div class="yt-card__play">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="white"><polygon points="9.5,7.5 16.5,12 9.5,16.5"/></svg>
            </div>
          </div>
          <div class="yt-card__info">
            <h3 class="yt-card__title">${v.title}</h3>
            <span class="yt-card__meta">${v.views ? v.views.toLocaleString('tr-TR') + ' görüntülenme' : ''}</span>
          </div>
        </a>
      `).join('');
    } catch {
      grid.innerHTML = '<p style="color:#888;text-align:center">Videolar yüklenemedi.</p>';
    }
  }
  loadYouTubeVideos();
</script>

<style>
  .yt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
    min-height: 200px;
  }

  .yt-loading {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-text-tertiary);
    padding: 3rem 0;
  }

  .yt-card {
    background: var(--color-bg-card);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }
  .yt-card:hover {
    border-color: rgba(255,0,0,0.4);
    transform: translateY(-2px);
  }

  .yt-card__thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .yt-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }
  .yt-card:hover .yt-card__thumb img { transform: scale(1.05); }

  .yt-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.3);
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  .yt-card:hover .yt-card__play { opacity: 1; }

  .yt-card__info { padding: var(--space-md); }
  .yt-card__title {
    font-size: var(--text-small);
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.3rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .yt-card__meta {
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
  }

  .yt-more {
    text-align: center;
    margin-top: var(--space-xl);
  }
  .yt-more__link {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--color-accent);
    letter-spacing: 0.05em;
    transition: color var(--transition-fast);
  }
  .yt-more__link:hover { color: var(--color-white); }
</style>
