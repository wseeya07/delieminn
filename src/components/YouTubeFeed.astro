---
import SectionHeader from './ui/SectionHeader.astro';
---
<section class="section" id="youtube">
  <div class="container">
    <SectionHeader label="YouTube">Son Videolarımız</SectionHeader>
    <div class="yt-grid" id="ytGrid">
      <div class="yt-loading">Videolar yükleniyor...</div>
    </div>
    <div class="yt-more">
      <a href="https://youtube.com/@delieminn" target="_blank" rel="noopener noreferrer" class="yt-more__link">
        Tüm Videolar →
      </a>
    </div>
  </div>
</section>

<script>
  async function loadYouTubeVideos() {
    const grid = document.getElementById('ytGrid');
    try {
      const res = await fetch('/api/youtube');
      if (!res.ok) throw new Error();
      const videos = await res.json();

      if (!videos.length) {
        grid.innerHTML = '<p style="color:#888;text-align:center">Videolar yüklenemedi.</p>';
        return;
      }

      grid.innerHTML = videos.map(v => `
        <a href="https://www.youtube.com/watch?v=${v.id}" target="_blank" rel="noopener noreferrer" class="yt-card">
          <div class="yt-card__frame">
            <div class="yt-card__thumb">
              <img src="https://i.ytimg.com/vi/${v.id}/mqdefault.jpg" alt="${v.title}" loading="lazy" />
              <div class="yt-card__play">
                <svg width="52" height="52" viewBox="0 0 68 48"><path d="M66.5 7.7s-.7-4.7-2.8-6.8C60.7.2 57.5.2 56 0 46.7-.6 33.8 0 33.8 0S20.9-.6 11.7 0C10.2.2 7 .2 4 .9 1.9 3 1.2 7.7 1.2 7.7S.5 13.2.5 18.8v5.2c0 5.5.7 11 .7 11s.7 4.7 2.8 6.8c3 3.1 6.9 3 8.7 3.3 6.3.6 26.8.9 26.8.9s13.1 0 22.3-.7c1.5-.2 4.7-.2 7.7-.9 2.1-2.1 2.8-6.8 2.8-6.8s.7-5.5.7-11v-5.2c0-5.6-.7-11.1-.7-11.1z" fill="#FF0000"/><path d="M27 33V14l18.4 9.5z" fill="#FFF"/></svg>
              </div>
            </div>
          </div>
          <div class="yt-card__info">
            <h3 class="yt-card__title">${v.title}</h3>
            <span class="yt-card__meta">${v.views ? v.views.toLocaleString('tr-TR') + ' görüntülenme' : ''}</span>
          </div>
        </a>
      `).join('');
    } catch {
      grid.innerHTML = '<p style="color:#888;text-align:center">Videolar yüklenemedi.</p>';
    }
  }
  loadYouTubeVideos();
</script>

<style>
  .yt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
    min-height: 200px;
  }

  .yt-loading {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-text-tertiary);
    padding: 3rem 0;
  }

  .yt-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .yt-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
  }

  .yt-card__frame {
    padding: 10px 10px 0;
    background: rgba(255,255,255,0.06);
    border: 2px solid rgba(255,255,255,0.12);
    border-bottom: none;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .yt-card__thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: 6px;
  }
  .yt-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }
  .yt-card:hover .yt-card__thumb img { transform: scale(1.05); }

  .yt-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
    transition: opacity var(--transition-base);
  }
  .yt-card__play svg { filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5)); }
  .yt-card:hover .yt-card__play { opacity: 1; }

  .yt-card__info { padding: var(--space-md); }
  .yt-card__title {
    font-size: var(--text-small);
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.3rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .yt-card__meta {
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
  }

  .yt-more {
    text-align: center;
    margin-top: var(--space-xl);
  }
  .yt-more__link {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--color-accent);
    letter-spacing: 0.05em;
    transition: color var(--transition-fast);
  }
  .yt-more__link:hover { color: var(--color-white); }
</style>
