---
import process from '../data/process.json';
import SectionHeader from './ui/SectionHeader.astro';
---
<section class="section section--alt" id="surec">
  <div class="container">
    <SectionHeader label="Nasıl Çalışıyoruz">Sürecimiz</SectionHeader>
    <div class="process__timeline reveal-stagger">
      {process.map((step, i) => (
        <div class="process__step">
          <span class="process__number font-mono">0{step.step}</span>
          <div class="process__line"></div>
          <h3 class="process__title">{step.title}</h3>
          <p class="process__desc">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process__timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .process__step {
    position: relative;
    padding-top: var(--space-xl);
  }

  .process__number {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--color-accent);
    font-weight: 500;
    display: block;
    margin-bottom: var(--space-md);
  }

  .process__line {
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, var(--color-accent), var(--color-border));
    margin-bottom: var(--space-lg);
  }

  .process__title {
    font-size: var(--text-h3);
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .process__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-small);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .process__timeline {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      border-left: 1px solid var(--color-border);
      padding-left: var(--space-xl);
    }
    .process__line { display: none; }
    .process__step { padding-top: 0; }
    .process__step::before {
      content: '';
      position: absolute;
      left: calc(-1 * var(--space-xl) - 4px);
      top: 0.5rem;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--color-accent);
    }
  }
</style>
